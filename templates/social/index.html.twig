{% extends 'base.html.twig' %}

{% block title %}Social{% endblock %}

{% block body %}
    <div class="app-shell max-w-md mx-auto pb-28">
        <header class="app-header mb-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">Communication Interface</p>
                    <h1 class="text-2xl font-bold text-app">Contacts</h1>
                </div>
            </div>
        </header>

        <section class="space-y-4 mb-3">
            {% if character.characterContacts|length > 0 %}
                <div class="grid grid-cols-1 gap-3">
                    {% for cc in character.characterContacts %}
                        <a href="{{ path('app_social_conversation', {id: cc.id}) }}" class="group relative flex items-stretch overflow-hidden rounded-2xl border border-app bg-panel shadow-neon-soft transition hover:bg-panel-2 min-h-[80px]">
                            <div class="relative w-24 shrink-0 border-r border-app/30 bg-panel-2">
                                {% if cc.contact.image %}
                                    <img src="{{ asset('uploads/images/' ~ cc.contact.image.storageName) }}" class="h-full w-full object-cover">
                                {% else %}
                                    <div class="flex h-full w-full items-center justify-center text-muted">
                                        <i class="fas fa-user text-xl"></i>
                                    </div>
                                {% endif %}
                            </div>
                            
                            <div class="flex-1 min-w-0 p-4 flex flex-col justify-center">
                                <div class="flex items-center justify-between gap-2">
                                    <h3 class="truncate text-sm font-bold uppercase tracking-wider text-app">{{ cc.contact.name }}</h3>
                                </div>
                                <div class="mt-1 flex items-center justify-between gap-2">
                                    <p class="truncate text-xs text-muted">
                                        {% if cc.messages|length > 0 %}
                                            {{ cc.messages.last.content }}
                                        {% else %}
                                            Aucun message
                                        {% endif %}
                                    </p>
                                    {% set unreadCount = cc.unreadCount %}
                                    {% if unreadCount > 0 %}
                                        <span class="shrink-0 flex h-5 w-5 items-center justify-center rounded-full bg-accent text-[10px] font-bold text-black shadow-neon">
                                            {{ unreadCount }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="flex flex-col items-center justify-center py-12 text-center">
                    <div class="mb-4 text-4xl text-muted/30">
                        <i class="fas fa-comment-slash"></i>
                    </div>
                    <p class="text-sm uppercase tracking-widest text-muted">Aucun contact disponible</p>
                </div>
            {% endif %}
        </section>

        {% include "main/_nav.html.twig" %}
    </div>

    <script>
        const socialUrl = "https://archadia.net/social/{{ character.id }}";
        const eventSource = new EventSource("{{ mercure_public_url|default('https://example.com/.well-known/mercure') }}?topic=" + encodeURIComponent(socialUrl));
        
        eventSource.onmessage = event => {
            const data = JSON.parse(event.data);
            if (data.type === 'message') {
                // Recharger la page pour voir les nouveaux messages et mettre à jour le compteur
                // Dans une approche "rechargement de page", c'est le plus simple
                window.location.reload();
            }
        };
    </script>
{% endblock %}
