{% extends 'base.html.twig' %}

{% block title %}Conversation avec {{ characterContact.contact.name }}{% endblock %}

{% block body %}
    <div class="app-shell flex flex-col h-screen max-w-md mx-auto">
        <header class="app-header p-4 border-b border-app/30 bg-panel/80 backdrop-blur-md">
            <div class="flex items-center gap-4">
                <a href="{{ path('app_social') }}" class="text-muted hover:text-app">
                    <i class="fas fa-chevron-left text-xl"></i>
                </a>
                <div class="flex items-center gap-3">
                    <div class="h-10 w-10 overflow-hidden rounded-lg border border-accent bg-panel-2">
                        {% if characterContact.contact.image %}
                            <img src="{{ asset('uploads/images/' ~ characterContact.contact.image.storageName) }}" class="h-full w-full object-cover">
                        {% else %}
                            <div class="flex h-full w-full items-center justify-center text-muted">
                                <i class="fas fa-user text-sm"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div>
                        <h1 class="text-sm font-bold uppercase tracking-widest text-app">{{ characterContact.contact.name }}</h1>
                        <p class="text-[10px] text-ok flex items-center gap-1">
                            <span class="h-1.5 w-1.5 rounded-full bg-ok animate-pulse"></span>
                            En ligne
                        </p>
                    </div>
                </div>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto p-4 space-y-4 scroll-smooth" id="message-container">
            {% for message in characterContact.messages %}
                <div class="flex {{ message.isFromContact ? 'justify-start' : 'justify-end' }}">
                    <div class="max-w-[85%] space-y-1">
                        <div class="rounded-2xl px-4 py-2 text-sm {{ message.isFromContact ? 'bg-panel-2 border border-app/50 text-app rounded-tl-none' : 'bg-accent/20 border border-accent/30 text-accent rounded-tr-none shadow-neon-soft' }}">
                            {{ message.content|nl2br }}
                        </div>
                    </div>
                </div>
            {% endfor %}
            <div id="anchor"></div>
        </main>

        <footer class="p-4 bg-panel/80 backdrop-blur-md border-t border-app/30">
            <form method="POST" class="flex gap-2">
                <input 
                    type="text" 
                    name="content" 
                    placeholder="Écrire un message..." 
                    class="flex-1 rounded-xl border border-app bg-panel px-4 py-3 text-sm text-app focus:border-accent focus:outline-none focus:shadow-neon-soft"
                    autocomplete="off"
                    required
                >
                <button type="submit" class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent text-black shadow-neon transition hover:scale-105 active:scale-95">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </form>
        </footer>
    </div>

    <script>
        window.onload = () => {
            const container = document.getElementById('message-container');
            container.scrollTop = container.scrollHeight;
        };

        const socialUrl = "https://archadia.net/social/{{ character.id }}";
        const eventSource = new EventSource("{{ mercure_public_url|default('https://example.com/.well-known/mercure') }}?topic=" + encodeURIComponent(socialUrl));
        
        eventSource.onmessage = event => {
            const data = JSON.parse(event.data);
            if (data.type === 'message' && data.conversationId == {{ characterContact.id }}) {
                window.location.reload();
            }
        };
    </script>
{% endblock %}
