{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as macros %}
{% block title %}Actions{% endblock %}

{% block body %}
    <div class="app-shell pb-28">

        <header class="app-header mb-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">
                        Edgerunner interface
                    </p>
                    <h1 class="text-2xl font-bold text-app">
                        Actions
                    </h1>
                </div>
                <div class="flex flex-col gap-2 items-end">
                    <a href="{{ path('app_character_actions_reset') }}" class="flex items-center gap-2 rounded-lg border border-app/30 bg-app/5 px-3 py-2 text-xs font-bold uppercase tracking-wider text-app transition-all hover:bg-app/20 active:scale-95">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                        Réinitialiser
                    </a>

                    <a href="{{ path('app_character_summary') }}" class="flex items-center gap-2 rounded-lg border border-accent/30 bg-accent/5 px-3 py-2 text-xs font-bold uppercase tracking-wider text-accent transition-all hover:bg-accent/20 active:scale-95">
                        <i class="fas fa-file-alt"></i>
                        Résumé
                    </a>
                </div>
            </div>
        </header>

        <div class="space-y-4">
            <section class="card card--neon scanlines">
                <div class="space-y-5">
                    <div class="flex items-center justify-between">
                    </div>

                    {% for typeName, actionsForType in actions %}
                        <div class="space-y-3">
                            <div class="border-b border-app pb-2">
                                <h3 class="text-xs font-semibold uppercase tracking-[0.24em] text-muted">
                                    {{ typeName }}
                                </h3>
                            </div>

                            <div class="grid grid-cols-2 gap-3">
                                {% for actionData in actionsForType %}
                                    {% set action = actionData.object %}
                                    <div class="rounded-2xl border border-app bg-panel p-4 shadow-neon-soft">
                                        <div class="flex h-full min-h-[140px] flex-col">
                                            <div class="flex items-start justify-between gap-3">
                                                <div class="min-w-0">
                                                    <div class="text-sm font-semibold uppercase tracking-[0.16em] text-app">
                                                        {{ action.name }}
                                                    </div>

                                                    {# Origin: Feat or Item type with icon #}
                                                    {% if actionData.originType is defined and actionData.originType %}
                                                        <div class="mt-0.5 text-[10px] uppercase tracking-[0.14em] text-muted flex items-center gap-1.5">
                                                            {% if actionData.originType == 'feat' %}
                                                                <i class="fas fa-bolt text-accent"></i>
                                                                <span>Feat · {{ actionData.originName|default('') }}</span>
                                                            {% elseif actionData.originType == 'item' %}
                                                                {% set itype = actionData.originItemType|default(null) %}
                                                                {% if itype == constant('App\\Entity\\Item::TYPE_CYBERWARE') %}
                                                                    <i class="fas fa-microchip text-neon"></i>
                                                                    <span>Cyberware · {{ actionData.originName|default('') }}</span>
                                                                {% elseif itype == constant('App\\Entity\\Item::TYPE_EQUIPEMENT') %}
                                                                    <i class="fas fa-toolbox text-app"></i>
                                                                    <span>Équipement · {{ actionData.originName|default('') }}</span>
                                                                {% elseif itype == constant('App\\Entity\\Item::TYPE_CONSOMMABLE') %}
                                                                    <i class="fas fa-flask text-accent"></i>
                                                                    <span>Consommable · {{ actionData.originName|default('') }}</span>
                                                                {% else %}
                                                                    <i class="fas fa-box"></i>
                                                                    <span>{{ actionData.originName|default('') }}</span>
                                                                {% endif %}
                                                            {% endif %}
                                                        </div>
                                                    {% endif %}

                                                    {% if action.item %}
                                                        <div class="mt-1 text-[10px] uppercase tracking-[0.14em] text-accent text-neon">
                                                            {% if actionData.amount is not null %}
                                                                 {{ actionData.amount }} restants
                                                            {% endif %}
                                                        </div>
                                                        {% if action.item.isAmmo and (action.item.chargePrice ?? 0) > 0 and actionData.characterItemId %}
                                                            <div class="mt-1">
                                                                <a href="{{ path('app_character_item_recharge', {id: actionData.characterItemId}) }}"
                                                                   class="inline-flex items-center gap-1.5 rounded-lg border border-accent/30 bg-accent/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-accent hover:bg-accent/20 active:scale-95">
                                                                    <i class="fas fa-add"></i>
                                                                    {{ action.item.chargePrice }}{{ macros.dragon('w-3 h-3') }}
                                                                </a>
                                                            </div>
                                                        {% endif %}
                                                    {% endif %}

                                                    <div class="mt-1 flex items-center gap-2">
                                                        <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-app bg-app/10 px-1.5 py-0.5 rounded border border-app/20">
                                                            {{ action.usage|default('action') }}
                                                        </span>
                                                        {% if action.maxUse %}
                                                            <span class="text-[10px] font-mono text-muted">
                                                                {{ action.uses|default(0) }}/{{ action.maxUse }}
                                                            </span>
                                                        {% endif %}
                                                        {% if action.cout > 0 %}
                                                            <div class="flex items-center gap-1.5 ml-1">
                                                                {% for i in 1..action.cout %}
                                                                    <i class="fas fa-dice-six text-sm text-accent"></i>
                                                                {% endfor %}
                                                            </div>
                                                        {% endif %}
                                                    </div>
                                                </div>

                                                <div class="flex flex-col gap-1">
                                                    {% set isAmmoAction = action.item and action.item.isAmmo %}
                                                    {# Priorité: pour les munitions, on décrémente la quantité d'item (ammo) même si l'action a aussi des usages #}
                                                    {% if isAmmoAction and actionData.characterItemId and actionData.amount > 0 %}
                                                        <a href="{{ path('app_character_action_decrement', {'id': actionData.characterItemId, 'type': 'item'}) }}"
                                                           class="flex h-8 w-8 items-center justify-center rounded-lg border border-accent/30 bg-accent/5 text-accent transition-all hover:bg-accent/20 active:scale-95">
                                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                                                            </svg>
                                                        </a>
                                                    {% elseif action.maxUse and action.uses > 0 %}
                                                        <a href="{{ path('app_character_action_decrement', {'id': action.id, 'type': 'action'}) }}"
                                                           class="flex h-8 w-8 items-center justify-center rounded-lg border border-app/30 bg-app/5 text-app transition-all hover:bg-app/20 active:scale-95">
                                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                                                            </svg>
                                                        </a>
                                                    {% elseif actionData.characterItemId and actionData.amount > 0 %}
                                                        <a href="{{ path('app_character_action_decrement', {'id': actionData.characterItemId, 'type': 'item'}) }}"
                                                           class="flex h-8 w-8 items-center justify-center rounded-lg border border-accent/30 bg-accent/5 text-accent transition-all hover:bg-accent/20 active:scale-95">
                                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                                                            </svg>
                                                        </a>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            <div class="mt-3 flex-1 text-xs leading-relaxed text-muted">
                                                {{ action.description|parse_description }}
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>

        </div>
    </div>
{% endblock %}
