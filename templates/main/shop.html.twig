{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as macros %}

{% block title %}Shop - Archadia{% endblock %}

{% block body %}
    <div class="app-shell max-w-md mx-auto pb-28">

        <header class="app-header mb-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">Black Market</p>
                    <h1 class="text-2xl font-bold text-app">Shop</h1>
                </div>
                <div class="text-right">
                    <p class="text-[10px] uppercase tracking-widest text-muted">Crédits</p>
                    <div class="flex items-center gap-1.5 text-lg font-bold text-accent text-neon">
                        {{ character.money|number_format(0, '.', ' ') }}
                        {{ macros.dragon('w-4 h-4') }}
                    </div>
                </div>
            </div>
        </header>

        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded-lg bg-danger/20 border border-danger/50 p-3 text-xs text-danger animate-pulse">
                {{ message }}
            </div>
        {% endfor %}

        <div class="space-y-4">
            <section class="grid grid-cols-1 gap-4">
                {% for item in items %}
                    <div class="card card--neon scanlines rounded-2xl border border-app bg-panel p-4 shadow-neon-soft overflow-hidden relative">
                        <div class="flex gap-4">
                            <div class="w-20 h-20 rounded-xl border border-app bg-panel-2 flex-shrink-0 overflow-hidden">
                                {% if item.illustration %}
                                    <img src="{{ asset('uploads/images/' ~ item.illustration.storageName) }}" alt="{{ item.name }}" class="w-full h-full object-cover opacity-80">
                                {% else %}
                                    <div class="w-full h-full flex items-center justify-center text-muted">
                                        <i class="fas fa-box"></i>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-start justify-between">
                                    <h3 class="text-sm font-bold uppercase tracking-wider text-app truncate">
                                        {{ item.name }}
                                    </h3>
                                    <span class="text-[10px] uppercase px-1.5 py-0.5 rounded bg-app/10 border border-app/20 text-muted">
                                        {{ item.type }}
                                    </span>
                                </div>
                                <p class="mt-1 text-[10px] text-muted leading-relaxed line-clamp-2 italic">
                                    "{{ item.description }}"
                                </p>
                                <div class="mt-3 flex items-center justify-between">
                                    <div class="flex items-center gap-1.5 font-bold text-accent">
                                        {{ item.price }} {{ macros.dragon('w-3.5 h-3.5') }}
                                    </div>
                                    <div class="text-[10px] text-muted">
                                        {% if item.isInfiniteStock %}
                                            Stock : ∞
                                        {% else %}
                                            Stock : {{ item.stock }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4 pt-4 border-t border-app/30">
                            <a href="{{ path('app_character_shop_buy', {id: item.id}) }}" 
                               class="flex w-full items-center justify-center gap-2 rounded-xl border border-accent/50 bg-accent/10 py-2 text-xs font-bold uppercase tracking-widest text-accent transition-all hover:bg-accent/20 active:scale-[0.98] {{ character.money < item.price ? 'opacity-50 pointer-events-none grayscale' : '' }}">
                                <i class="fas fa-shopping-cart"></i>
                                Acheter
                            </a>
                        </div>
                    </div>
                {% else %}
                    <div class="text-center py-12 text-muted italic">
                        Le marché noir semble vide pour le moment...
                    </div>
                {% endfor %}
            </section>

            {% include "main/_nav.html.twig" %}
        </div>
    </div>

    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', () => {
            const eventSource = new EventSource("{{ (mercure_public_url|default('https://example.com/.well-known/mercure')) ~ '?topic=' ~ ('https://archadia.net/shop'|url_encode) }}");
            
            eventSource.onmessage = event => {
                // On recharge la page pour mettre à jour les stocks et prix
                window.location.reload();
            };
        });
    </script>
{% endblock %}
