{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as macros %}

{% block title %}Inventaire{% endblock %}

{% block body %}
    <div class="app-shell max-w-md mx-auto pb-28">

        <header class="app-header mb-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">
                        Edgerunner interface
                    </p>
                    <h1 class="text-2xl font-bold text-app">
                        {{ character.nom }}
                    </h1>
                </div>
            </div>
        </header>

        <div class="space-y-4">
            <section class="card card--neon scanlines">
                <div class="space-y-5">
                    <div class="flex items-center justify-between">
                        <h2 class="text-sm font-semibold uppercase tracking-[0.24em] text-muted">
                            Inventaire
                        </h2>
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_character_shop') }}" class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-accent bg-panel px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-accent shadow-neon-soft transition-all hover:bg-panel-2">
                                <i class="fas fa-shopping-cart"></i>
                                Shop
                            </a>
                            <details class="relative">
                                <summary class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-app bg-panel px-4 py-1.5 text-[10px] font-bold uppercase tracking-widest text-app shadow-neon-soft transition-all hover:bg-panel-2">
                                    <i class="fas fa-microchip"></i>
                                    Cyberware
                                </summary>
                                <div class="absolute right-0 top-full z-10 mt-2 w-72 rounded-2xl border border-app bg-panel p-4 shadow-2xl backdrop-blur-md">
                                    <div class="mb-4 border-b border-app/30 pb-2 flex items-center justify-between">
                                        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-accent text-neon">Cyberwares Installés</h3>
                                    </div>
                                    <div class="max-h-[60vh] space-y-3 overflow-y-auto pr-1 custom-scrollbar">
                                        {% set hasCyber = false %}
                                        {% for ci in character.items %}
                                            {% if ci.item.type == constant('App\\Entity\\Item::TYPE_CYBERWARE') and ci.isInstalled %}
                                                {% set hasCyber = true %}
                                                {% set item = ci.item %}
                                                <div class="group relative rounded-xl border border-app/40 bg-panel-2/50 p-3 transition-all hover:border-accent/50 hover:bg-panel-2">
                                                    <div class="flex gap-3">
                                                        <div class="h-10 w-10 shrink-0 rounded-lg border border-app/30 bg-panel flex items-center justify-center overflow-hidden">
                                                            {% if item.illustration %}
                                                                {% set illustrationPath = 'uploads/images/' ~ item.illustration.storageName %}
                                                                {% if item.illustration.storageName == 'item.png' %}{% set illustrationPath = 'img-asset/item.png' %}{% endif %}
                                                                <img src="{{ asset(illustrationPath) }}" class="h-8 w-8 object-contain opacity-80 group-hover:opacity-100 transition-opacity">
                                                            {% else %}
                                                                <i class="fas fa-microchip text-app/30"></i>
                                                            {% endif %}
                                                        </div>
                                                        <div class="min-w-0 flex-1">
                                                            <div class="text-[11px] font-bold uppercase tracking-wider text-app">{{ item.name }}</div>
                                                        </div>
                                                    </div>
                                                    <div class="mt-2 text-[10px] leading-relaxed text-muted italic line-clamp-3 group-hover:line-clamp-none transition-all">
                                                        "{{ item.description }}"
                                                    </div>
                                                </div>
                                            {% endif %}
                                        {% endfor %}
                                        {% if not hasCyber %}
                                            <div class="py-8 text-center">
                                                <div class="mb-2 text-2xl opacity-20 text-app">∅</div>
                                                <p class="text-[10px] text-muted uppercase tracking-widest italic font-bold">Zéro chrome détecté</p>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </details>
                        </div>
                    </div>

                    <div class="space-y-8">
                        {% set equippedItems = [] %}
                        {% set consumables = [] %}
                        {% set otherItems = [] %}

                        {% for ci in character.items %}
                            {% if ci.item.type == constant('App\\Entity\\Item::TYPE_CYBERWARE') %}
                                {# On n'affiche pas les cyberwares installés dans la liste principale #}
                                {% if not ci.isInstalled %}
                                    {% set otherItems = otherItems|merge([ci]) %}
                                {% endif %}
                            {% elseif ci.item.type == constant('App\\Entity\\Item::TYPE_EQUIPEMENT') %}
                                {% if ci.isEquipped %}
                                    {% set equippedItems = equippedItems|merge([ci]) %}
                                {% else %}
                                    {% set otherItems = otherItems|merge([ci]) %}
                                {% endif %}
                            {% elseif ci.item.type == constant('App\\Entity\\Item::TYPE_CONSOMMABLE') %}
                                {% set consumables = consumables|merge([ci]) %}
                            {% else %}
                                {% set otherItems = otherItems|merge([ci]) %}
                            {% endif %}
                        {% endfor %}

                        {# SECTION ÉQUIPÉS #}
                        {% if equippedItems|length > 0 %}
                            <div class="space-y-3">
                                <div class="border-b border-app/30 pb-1">
                                    <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-accent text-neon">Équipé</h3>
                                </div>
                                <div class="space-y-3">
                                    {% for ci in equippedItems|sort((a, b) => a.item.name <=> b.item.name) %}
                                        {{ _self.renderItem(ci, false) }}
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# SECTION CONSOMMABLES #}
                        {% if consumables|length > 0 %}
                            <div class="space-y-3">
                                <div class="border-b border-app/30 pb-1">
                                    <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted">Consommables</h3>
                                </div>
                                <div class="space-y-3">
                                    {% for ci in consumables|sort((a, b) => a.item.name <=> b.item.name) %}
                                        {{ _self.renderItem(ci, false) }}
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# SECTION LE RESTE (CONDENSÉ) #}
                        {% if otherItems|length > 0 or character.stuffs|length > 0 %}
                            <div class="space-y-3">
                                <div class="border-b border-app/30 pb-1">
                                    <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted">Divers & Réserve</h3>
                                </div>
                                <div class="grid grid-cols-1 gap-2">
                                    {% for ci in otherItems|sort((a, b) => a.item.name <=> b.item.name) %}
                                        {{ _self.renderItem(ci, true) }}
                                    {% endfor %}
                                    {% for stuff in character.stuffs|sort((a, b) => a.title <=> b.title) %}
                                        <details class="group">
                                            <summary class="flex cursor-pointer list-none items-center justify-between rounded-xl border border-app/40 bg-panel/50 px-3 py-2 transition-all hover:bg-panel-2">
                                                <div class="min-w-0">
                                                    <div class="truncate text-[11px] font-bold uppercase tracking-wider text-app">{{ stuff.title }}</div>
                                                </div>
                                                <div class="flex items-center gap-2">
                                                    <a href="{{ path('app_stuff_edit', {id: stuff.id}) }}" class="text-[10px] text-muted hover:text-accent p-1">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <div class="text-[10px] italic text-muted/60">Divers</div>
                                                </div>
                                            </summary>
                                            <div class="mt-1 px-3 py-2 text-[10px] text-muted border-t border-app/10 bg-panel/30 rounded-b-xl">
                                                {{ stuff.description }}
                                            </div>
                                        </details>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        <div class="pt-4">
                            <a href="{{ path('app_stuff_new') }}" class="flex w-full items-center justify-center gap-2 rounded-xl border-2 border-dashed border-app/40 py-3 text-xs font-bold uppercase tracking-widest text-muted transition-colors hover:border-app hover:text-app">
                                <i class="fas fa-plus"></i>
                                Nouveau
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            {% include "main/_nav.html.twig" %}
        </div>
    </div>
{% endblock %}

{% macro renderItem(ci, condensed) %}
    {% set item = ci.item %}
    {% import "_macros.html.twig" as macros %}
    
    {% if condensed %}
        <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 rounded-xl border border-app/50 bg-panel/40 p-2 transition-all hover:bg-panel-2">
                <div class="flex items-center gap-2 min-w-0">
                    <div class="h-6 w-6 shrink-0 rounded border border-app/30 bg-panel-2 overflow-hidden flex items-center justify-center">
                        {% if item.illustration %}
                            {% set illustrationPath = 'uploads/images/' ~ item.illustration.storageName %}
                            {% if item.illustration.storageName == 'item.png' %}{% set illustrationPath = 'img-asset/item.png' %}{% endif %}
                            <img src="{{ asset(illustrationPath) }}" class="h-4 w-4 object-contain opacity-70">
                        {% endif %}
                    </div>
                    <div class="truncate text-[11px] font-semibold uppercase tracking-wider text-app/80">
                        {{ item.name }}
                        {% if ci.amount > 1 and not ci.isEquipped %}<span class="ml-1 text-accent">(x{{ ci.amount }})</span>{% endif %}
                        {% if item.isCumbersome %}<span class="inline-block w-2 h-2 bg-orange-500 ml-1" title="Encombrant"></span>{% endif %}
                        {% if not item.isLegal %}<span class="inline-block w-0 h-0 border-l-[5px] border-l-transparent border-r-[5px] border-r-transparent border-b-[8px] border-b-red-600 ml-1" title="Illégal"></span>{% endif %}
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    {% if item.type == constant('App\\Entity\\Item::TYPE_CYBERWARE') %}
                        <a href="{{ path('app_character_item_install', {id: ci.id}) }}" class="rounded bg-ok/10 px-2 py-0.5 text-[8px] font-black uppercase text-ok border border-ok/20 hover:bg-ok/20">Installer</a>
                    {% elseif item.type == constant('App\\Entity\\Item::TYPE_EQUIPEMENT') %}
                        <a href="{{ path('app_character_item_equip', {id: ci.id}) }}" class="rounded bg-accent/10 px-2 py-0.5 text-[8px] font-black uppercase text-accent border border-accent/20 hover:bg-accent/20">{{ ci.isEquipped ? 'Enlever' : 'Équiper' }}</a>
                    {% endif %}
                </div>
            </summary>
            <div class="mt-1 px-3 py-2 text-[10px] text-muted border-t border-app/10 bg-panel/30 rounded-b-xl">
                {{ item.description }}
            </div>
        </details>
    {% else %}
        <div class="overflow-hidden rounded-2xl border border-app bg-panel shadow-neon-soft">
            <div class="grid grid-cols-[76px_1fr_64px] items-stretch">
                <div class="flex items-center justify-center border-r border-app bg-panel-2 p-3">
                    <div class="flex h-14 w-14 items-center justify-center rounded-xl border border-app bg-panel overflow-hidden">
                        {% if item.illustration %}
                            {% set illustrationPath = 'uploads/images/' ~ item.illustration.storageName %}
                            {% if item.illustration.storageName == 'item.png' %}{% set illustrationPath = 'img-asset/item.png' %}{% endif %}
                            <img src="{{ asset(illustrationPath) }}" alt="{{ item.name }}" class="h-10 w-10 object-contain opacity-95">
                        {% endif %}
                    </div>
                </div>

                <div class="flex min-w-0 flex-col justify-center px-4 py-3">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <div class="truncate text-sm font-semibold uppercase tracking-[0.16em] text-app">
                                {{ item.name }}
                                {% if item.isCumbersome %}<span class="inline-block w-2.5 h-2.5 bg-orange-500 ml-2" title="Encombrant"></span>{% endif %}
                                {% if not item.isLegal %}<span class="inline-block w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-b-[10px] border-b-red-600 ml-2" title="Illégal"></span>{% endif %}
                            </div>
                            <div class="mt-1 flex items-center gap-2">
                                <div class="text-[10px] uppercase tracking-[0.14em] text-muted">
                                    {{ item.type }}
                                </div>
                                {% if item.type == constant('App\\Entity\\Item::TYPE_EQUIPEMENT') %}
                                    <a href="{{ path('app_character_item_equip', {id: ci.id}) }}" class="text-[10px] font-bold uppercase tracking-wider {{ ci.isEquipped ? 'text-accent' : 'text-muted' }}">
                                        <i class="fas {{ ci.isEquipped ? 'fa-check-circle' : 'fa-circle' }} mr-1"></i>{{ ci.isEquipped ? 'Enlever' : 'Équiper' }}
                                    </a>
                                {% elseif item.type == constant('App\\Entity\\Item::TYPE_CYBERWARE') %}
                                    <span class="text-[10px] font-bold uppercase tracking-wider text-muted">
                                        <i class="fas fa-circle mr-1"></i>Installer
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            {% if ci.amount is not null and not ci.isEquipped %}
                                <div class="shrink-0 rounded-full border border-accent bg-panel px-2 py-0.5 text-[10px] font-semibold text-accent text-neon">x{{ ci.amount }}</div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="mt-3 text-xs text-muted">{{ item.description }}</div>
                </div>
                {% if item.type == constant('App\\Entity\\Item::TYPE_CONSOMMABLE') and not ci.isEquipped %}
                    <div class="flex flex-col border-l border-app bg-panel-2/30">
                            <a href="{{ path('app_character_item_quantity', {id: ci.id, math: 'sub'}) }}" class="flex flex-1 items-center justify-center bg-accent/20 text-[10px] font-black uppercase tracking-widest text-accent transition hover:bg-accent/40 shadow-[inset_0_0_10px_rgba(var(--color-accent),0.1)]">Use</a>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endmacro %}
