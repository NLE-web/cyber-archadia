{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as macros %}

{% block title %}Inventaire{% endblock %}

{% block body %}
    <div class="app-shell max-w-md mx-auto pb-28">

        <header class="app-header mb-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">
                        Edgerunner interface
                    </p>
                    <h1 class="text-2xl font-bold text-app">
                        {{ character.nom }}
                    </h1>
                </div>
            </div>
        </header>

        <div class="space-y-4">
            <section class="card card--neon scanlines">
                <div class="space-y-5">
                    <div class="flex items-center justify-between">
                        <h2 class="text-sm font-semibold uppercase tracking-[0.24em] text-muted">
                            Inventaire
                        </h2>
                        <div class="flex items-center gap-1.5 rounded-full border border-accent/30 bg-accent/5 px-3 py-1 text-xs font-bold text-accent text-neon">
                            {{ character.money|number_format(0, '.', ' ') }}
                            {{ macros.dragon('w-3.5 h-3.5') }}
                        </div>
                    </div>

                    <div class="space-y-8">
                        {% set groupedItems = {
                            'Consommables': [],
                            'Équipement': [],
                            'Divers': []
                        } %}

                        {% for characterItem in character.items %}
                            {% set item = characterItem.item %}
                            {% if item.type == 'consommable' %}
                                {% set groupedItems = groupedItems|merge({'Consommables': groupedItems['Consommables']|merge([characterItem])}) %}
                            {% elseif item.type == 'equipement' %}
                                {% set groupedItems = groupedItems|merge({'Équipement': groupedItems['Équipement']|merge([characterItem])}) %}
                            {% else %}
                                {% set groupedItems = groupedItems|merge({'Divers': groupedItems['Divers']|merge([characterItem])}) %}
                            {% endif %}
                        {% endfor %}

                        {% for category, items in groupedItems %}
                            {% if items|length > 0 %}
                                <div class="space-y-3">
                                    <div class="border-b border-app/30 pb-1">
                                        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted">
                                            {{ category }}
                                        </h3>
                                    </div>
                                    <div class="space-y-3">
                                        {% for characterItem in items %}
                                            {% set item = characterItem.item %}
                                            <div class="overflow-hidden rounded-2xl border border-app bg-panel shadow-neon-soft">
                                                <div class="grid grid-cols-[76px_1fr_56px] items-stretch">

                                                    {# ILLUSTRATION A GAUCHE #}
                                                    <div class="flex items-center justify-center border-r border-app bg-panel-2 p-3">
                                                        <div class="flex h-14 w-14 items-center justify-center rounded-xl border border-app bg-panel overflow-hidden">
                                                            {% if item.illustration %}
                                                                {% set illustrationPath = 'uploads/images/' ~ item.illustration.storageName %}
                                                                {% if item.illustration.storageName == 'item.png' %}
                                                                    {% set illustrationPath = 'img-asset/item.png' %}
                                                                {% endif %}
                                                                <img
                                                                    src="{{ asset(illustrationPath) }}"
                                                                    alt="{{ item.name }}"
                                                                    class="h-10 w-10 object-contain opacity-95"
                                                                >
                                                            {% endif %}
                                                        </div>
                                                    </div>

                                                    {# CONTENU CENTRAL #}
                                                    <div class="flex min-w-0 flex-col justify-center px-4 py-3">
                                                        <div class="flex items-start justify-between gap-3">
                                                            <div class="min-w-0">
                                                                <div class="truncate text-sm font-semibold uppercase tracking-[0.16em] text-app">
                                                                    {{ item.name }}
                                                                </div>
                                                                <div class="mt-1 flex items-center gap-2">
                                                                    <div class="text-[10px] uppercase tracking-[0.14em] text-muted">
                                                                        {{ item.type }}
                                                                    </div>
                                                                    <div class="flex items-center gap-1">
                                                                        {% if item.isLegal == false %}
                                                                            <span title="Illégal" class="text-danger">
                                                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                                                                </svg>
                                                                            </span>
                                                                        {% endif %}
                                                                        {% if item.isCumbersome %}
                                                                            <span title="Encombrant" class="text-warn">
                                                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2z" />
                                                                                </svg>
                                                                            </span>
                                                                        {% endif %}
                                                                    </div>
                                                                </div>
                                                            </div>

                                                                <div class="flex items-center gap-2">
                                                                    {% if characterItem.amount is not null %}
                                                                        <div class="shrink-0 rounded-full border border-accent bg-panel px-2 py-0.5 text-[10px] font-semibold text-accent text-neon">
                                                                            x{{ characterItem.amount }}
                                                                        </div>
                                                                    {% endif %}
                                                                    {% if item.type == 'consommable' %}
                                                                        <div class="flex items-center gap-1 text-xs font-bold text-accent">
                                                                            {{ item.price|number_format(0, '.', ' ') }}
                                                                            {{ macros.dragon('w-3 h-3') }}
                                                                        </div>
                                                                    {% endif %}
                                                                </div>
                                                        </div>

                                                        <div class="mt-3 line-clamp-2 text-xs text-muted">
                                                            {{ item.description }}
                                                        </div>
                                                    </div>

                                                    {# ACTIONS A DROITE #}
                                                    <div class="flex flex-col border-l border-app">
                                                        {% if item.type == 'consommable' %}
                                                            <a
                                                                href="{{ path('app_character_item_quantity', {id: characterItem.id, math: 'add'}) }}"
                                                                class="flex flex-1 items-center justify-center border-b border-app bg-panel text-lg font-bold text-accent text-neon transition hover:bg-panel-2"
                                                                aria-label="Ajouter {{ item.name }}"
                                                            >
                                                                +
                                                            </a>
                                                        {% endif %}
                                                        <a
                                                            href="{{ path('app_character_item_quantity', {id: characterItem.id, math: 'sub'}) }}"
                                                            class="flex flex-1 items-center justify-center bg-panel text-lg font-bold text-app transition hover:bg-panel-2"
                                                            aria-label="Retirer {{ item.name }}"
                                                        >
                                                            −
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="rounded-2xl border border-app bg-panel p-4 text-sm text-muted">
                                Aucun objet trouvé.
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>

            {% include "main/_nav.html.twig" %}
        </div>
    </div>
{% endblock %}
