{% extends 'base.html.twig' %}
{% import "_macros.html.twig" as macros %}

{% block title %}Fiche personnage{% endblock %}

{% block body %}
    <div class="app-shell max-w-md mx-auto pb-28">

        {# HEADER APP #}
        <header class="app-header mb-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">Edgerunner interface</p>
                    <h1 class="text-2xl font-bold text-app">{{ character.nom }}</h1>
                </div>
            </div>
        </header>

        <div class="space-y-4">
            {# SECTION 1 — IDENTITÉ #}
            <section class="card card--neon scanlines">
                <div class="space-y-5">
                    <div class="flex justify-center">
                        <div class="relative overflow-hidden rounded-2xl border border-accent bg-panel shadow-neon w-44 h-44">
                            <img
                                src="{{ asset('uploads/images/'~character.avatar.storageName) }}"
                                alt="Avatar du personnage"
                                class="h-full w-full object-cover"
                            >
                            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                        </div>
                    </div>
                    <div class="grid grid-cols-3 gap-3">
                        <div class="rounded-2xl border border-app bg-panel p-4 text-center">
                            <div class="text-xs uppercase tracking-[0.24em] text-muted">FOR</div>
                            <div class="mt-2 text-2xl font-bold text-accent text-neon">{{ character.force }}</div>
                        </div>
                        <div class="rounded-2xl border border-app bg-panel p-4 text-center">
                            <div class="text-xs uppercase tracking-[0.24em] text-muted">DEX</div>
                            <div class="mt-2 text-2xl font-bold text-accent text-neon">{{ character.dexterite }}</div>
                        </div>
                        <div class="rounded-2xl border border-app bg-panel p-4 text-center">
                            <div class="text-xs uppercase tracking-[0.24em] text-muted">INT</div>
                            <div class="mt-2 text-2xl font-bold text-accent text-neon">{{ character.intelligence }}</div>
                        </div>
                    </div>

                    {# SECTION ARGENT #}
                    <div class="rounded-2xl border border-app bg-panel-2 p-4 text-center">
                        <div class="mb-1 text-[10px] uppercase tracking-[0.2em] text-accent/60">
                            XP: {{ character.xp|default(0) }}
                        </div>
                        <div class="text-[10px] uppercase tracking-[0.24em] text-muted">Dragons</div>
                        <div class="mt-2 flex items-center justify-center gap-2 text-2xl font-bold text-accent text-neon">
                            {{ character.money|number_format(0, '.', ' ') }}
                            {{ macros.dragon('w-6 h-6') }}
                        </div>

                        <details class="group mt-4">
                            <summary class="flex cursor-pointer list-none items-center justify-center gap-1.5 text-[10px] font-bold uppercase tracking-[0.2em] text-muted transition-colors hover:text-accent">
                                <span class="group-open:hidden">Modifier le solde</span>
                                <span class="hidden group-open:inline">Fermer l'interface</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </summary>

                            <form action="{{ path('app_maj_stat', {stat: 'money'}) }}" method="POST" class="mt-4 flex items-center justify-center gap-2">
                                <input
                                    type="number"
                                    name="value"
                                    value="100"
                                    min="1"
                                    class="w-20 rounded-lg border border-app bg-panel px-2 py-1 text-center text-sm font-bold text-app shadow-neon-soft focus:border-accent focus:outline-none"
                                    required
                                >
                                <div class="flex gap-2">
                                    <button
                                        type="submit"
                                        name="math"
                                        value="sub"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app bg-panel text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2 active:scale-95 transition-transform"
                                    >
                                        −
                                    </button>
                                    <button
                                        type="submit"
                                        name="math"
                                        value="add"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app bg-panel text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2 active:scale-95 transition-transform"
                                    >
                                        +
                                    </button>
                                </div>
                            </form>
                        </details>
                    </div>

                    {% set currentLife = character.lifepoints - character.lostlife %}
                    {% set lifePercent = (currentLife / (character.lifepoints+character.cyberpoints) * 100) %}
                    {% set currentCyber = character.cyberpoints - character.lostcyber %}
                    {% set cyberPercent = (currentCyber / (character.lifepoints+character.cyberpoints) * 100) %}
                    {% set stressPercent = (character.stresspoints / 20 * 100) %}

                    <div class="space-y-4">
                        {# ================= LIFE ================= #}
                        <div class="space-y-1">
                            <div class="flex items-center justify-between">
                                <span class="text-sm font-semibold text-app">PV</span>
                                <span class="text-sm text-muted">
                                    {{ currentLife }}/{{ character.lifepoints }}
                                    {% if character.cyberpoints > 0 %}
                                        <span class="ml-2 text-cyan-300">
                                            + {{ currentCyber }}/{{ character.cyberpoints }}
                                        </span>
                                    {% endif %}
                                </span>
                            </div>
                            <div class="flex h-3 w-full overflow-hidden rounded-full border border-app bg-panel">
                                {# SEGMENT VIE #}
                                <div
                                    class="h-full transition-all duration-300"
                                    style="
                                        width: {{ lifePercent }}%;
                                        background: var(--bar-life);
                                        box-shadow: 0 0 8px var(--bar-life-glow);
                                        "
                                ></div>
                                {# SEGMENT CYBER #}
                                {% if character.cyberpoints > 0 and currentCyber > 0 %}
                                    <div
                                        class="h-full transition-all duration-300"
                                        style="
                                            width: {{ cyberPercent }}%;
                                            background: linear-gradient(90deg,#6f7d8c,#9fb3c8);
                                            box-shadow: 0 0 8px var(--bar-cyber-glow);
                                            "
                                    ></div>
                                {% endif %}
                            </div>
                            <div class="flex items-center justify-between pt-1">
                                {# Boutons VIE à gauche #}
                                <div class="flex gap-2">
                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'life', math: 'sub', value: 1}) }}"
                                        style="background: var(--bar-life)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        −
                                    </a>

                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'life', math: 'add', value: 1}) }}"
                                        style="background: var(--bar-life)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        +
                                    </a>
                                </div>

                                {# Label central optionnel #}
                                <span class="text-[10px] uppercase tracking-[0.2em] text-muted">
                                    {% if character.cyberpoints > 0 %}Life / Cyber{% else %}Life{% endif %}
                                </span>

                                {# Boutons CYBER à droite #}
                                {% if character.cyberpoints > 0 %}
                                    <div class="flex gap-2">
                                        <a
                                            href="{{ path('app_maj_stat', {id: character.id, stat: 'cyber', math: 'sub', value: 1}) }}"
                                            style="background: linear-gradient(90deg,#6f7d8c,#9fb3c8)"
                                            class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                        >
                                            −
                                        </a>

                                        <a
                                            href="{{ path('app_maj_stat', {id: character.id, stat: 'cyber', math: 'add', value: 1}) }}"
                                            style="background: linear-gradient(90deg,#6f7d8c,#9fb3c8)"
                                            class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                        >
                                            +
                                        </a>
                                    </div>
                                {% else %}
                                    <div class="w-[72px]"></div>
                                {% endif %}
                            </div>
                        </div>

                        {# ================= STRESS ================= #}
                        <div class="space-y-1 relative" id="stress-container">
                            {% set breakdownFlashes = app.flashes('breakdown') %}
                            {% set hasBreakdown = breakdownFlashes|length > 0 %}
                            {% for message in breakdownFlashes %}
                                <div class="absolute -top-6 left-0 right-0 text-center animate-pulse duration-500 z-10" id="breakdown-message">
                                    <span class="text-xs font-black uppercase tracking-[0.3em] text-danger text-neon-danger">
                                        Breakdown
                                    </span>
                                </div>
                                <script>
                                    setTimeout(() => {
                                        const breakdown = document.getElementById('breakdown-message');
                                        const stressLabels = document.querySelectorAll('.stress-label');
                                        if (breakdown) {
                                            breakdown.style.transition = 'opacity 1s ease';
                                            breakdown.style.opacity = '0';
                                            setTimeout(() => {
                                                breakdown.remove();
                                                stressLabels.forEach(label => {
                                                    label.style.transition = 'opacity 1s ease';
                                                    label.style.opacity = '1';
                                                });
                                            }, 1000);
                                        }
                                    }, 5000);
                                </script>
                            {% endfor %}
                            <div class="flex items-center justify-between stress-label transition-opacity duration-500 {{ hasBreakdown ? 'opacity-0' : '' }}">
                                <span class="text-sm font-semibold text-app">STRESS</span>
                                <span class="text-sm text-muted">
                                </span>
                            </div>
                            <div class="h-2 w-full overflow-hidden rounded-full border border-app bg-panel">
                                <div
                                    class="h-full transition-all duration-300"
                                    style="
                                        width: {{ stressPercent }}%;
                                        background: var(--bar-stress);
                                        box-shadow: 0 0 8px var(--bar-life-glow);
                                        "
                                ></div>
                            </div>

                            <div class="flex items-center justify-between pt-1">
                                <div class="flex gap-2">
                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'stress', math: 'sub', value: 1}) }}"
                                        style="background: var(--bar-stress)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        −
                                    </a>

                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'stress', math: 'add', value: 1}) }}"
                                        style="background: var(--bar-stress)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        +
                                    </a>
                                </div>

                                <span class="text-[10px] uppercase tracking-[0.2em] text-muted stress-label transition-opacity duration-500 {{ hasBreakdown ? 'opacity-0' : '' }}">Stress</span>

                                <div class="w-[72px]"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            {% include "main/_nav.html.twig" %}
        </div>
    </div>
{% endblock %}
