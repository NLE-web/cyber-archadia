{% extends 'base.html.twig' %}

{% block title %}Fiche personnage{% endblock %}

{% block body %}
    <div class="app-shell max-w-md mx-auto pb-28">

        {# HEADER APP #}
        <header class="app-header mb-4">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">Edgerunner interface</p>
                    <h1 class="text-2xl font-bold text-app">{{ character.nom }}</h1>
                </div>
            </div>
        </header>

        <div class="space-y-4">
            {# SECTION 1 — IDENTITÉ #}
            <section class="card card--neon scanlines">
                <div class="space-y-5">
                    <div class="flex justify-center">
                        <div class="relative overflow-hidden rounded-2xl border border-accent bg-panel shadow-neon w-44 h-44">
                            <img
                                src="{{ asset('uploads/images/'~character.avatar.storageName) }}"
                                alt="Avatar du personnage"
                                class="h-full w-full object-cover"
                            >
                            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                        </div>
                    </div>
                    <div class="grid grid-cols-3 gap-3">
                        <div class="rounded-2xl border border-app bg-panel p-4 text-center">
                            <div class="text-xs uppercase tracking-[0.24em] text-muted">FOR</div>
                            <div class="mt-2 text-2xl font-bold text-accent text-neon">{{ character.force }}</div>
                        </div>
                        <div class="rounded-2xl border border-app bg-panel p-4 text-center">
                            <div class="text-xs uppercase tracking-[0.24em] text-muted">DEX</div>
                            <div class="mt-2 text-2xl font-bold text-accent text-neon">{{ character.dexterite }}</div>
                        </div>
                        <div class="rounded-2xl border border-app bg-panel p-4 text-center">
                            <div class="text-xs uppercase tracking-[0.24em] text-muted">INT</div>
                            <div class="mt-2 text-2xl font-bold text-accent text-neon">{{ character.intelligence }}</div>
                        </div>
                    </div>
                    {% set currentLife = character.lifepoints - character.lostlife %}
                    {% set lifePercent = (currentLife / (character.lifepoints+character.cyberpoints) * 100) %}
                    {% set currentCyber = character.cyberpoints - character.lostcyber %}
                    {% set cyberPercent = (currentCyber / (character.lifepoints+character.cyberpoints) * 100) %}
                    {% set stressPercent = (character.stresspoints / (character.intelligence * 5) * 100) %}

                    <div class="space-y-4">
                        {# ================= LIFE ================= #}
                        <div class="space-y-1">
                            <div class="flex items-center justify-between">
                                <span class="text-sm font-semibold text-app">PV</span>
                                <span class="text-sm text-muted">
                                    {{ currentLife }}/{{ character.lifepoints }}
                                    {% if character.cyberpoints > 0 %}
                                        <span class="ml-2 text-cyan-300">
                                            + {{ currentCyber }}/{{ character.cyberpoints }}
                                        </span>
                                    {% endif %}
                                </span>
                            </div>
                            <div class="flex h-3 w-full overflow-hidden rounded-full border border-app bg-panel">
                                {# SEGMENT VIE #}
                                <div
                                    class="h-full transition-all duration-300"
                                    style="
                                        width: {{ lifePercent }}%;
                                        background: var(--bar-life);
                                        box-shadow: 0 0 8px var(--bar-life-glow);
                                        "
                                ></div>
                                {# SEGMENT CYBER #}
                                {% if currentCyber > 0 %}
                                    <div
                                        class="h-full transition-all duration-300"
                                        style="
                                            width: {{ cyberPercent }}%;
                                            background: linear-gradient(90deg,#6f7d8c,#9fb3c8);
                                            box-shadow: 0 0 8px var(--bar-cyber-glow);
                                            "
                                    ></div>
                                {% endif %}
                            </div>
                            <div class="flex items-center justify-between pt-1">
                                {# Boutons VIE à gauche #}
                                <div class="flex gap-2">
                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'life', math: 'sub', value: 1}) }}"
                                        style="background: var(--bar-life)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        −
                                    </a>

                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'life', math: 'add', value: 1}) }}"
                                        style="background: var(--bar-life)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        +
                                    </a>
                                </div>

                                {# Label central optionnel #}
                                <span class="text-[10px] uppercase tracking-[0.2em] text-muted">Life / Cyber</span>

                                {# Boutons CYBER à droite #}
                                <div class="flex gap-2">
                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'cyber', math: 'sub', value: 1}) }}"
                                        style="background: linear-gradient(90deg,#6f7d8c,#9fb3c8)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        −
                                    </a>

                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'cyber', math: 'add', value: 1}) }}"
                                        style="background: linear-gradient(90deg,#6f7d8c,#9fb3c8)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        +
                                    </a>
                                </div>
                            </div>
                        </div>

                        {# ================= STRESS ================= #}
                        <div class="space-y-1">
                            <div class="flex items-center justify-between">
                                <span class="text-sm font-semibold text-app">STRESS</span>
                                <span class="text-sm text-muted">
                                    {{ character.stresspoints }}
                                </span>
                            </div>
                            <div class="h-2 w-full overflow-hidden rounded-full border border-app bg-panel">
                                <div
                                    class="h-full transition-all duration-300"
                                    style="
                                        width: {{ stressPercent }}%;
                                        background: var(--bar-stress);
                                        box-shadow: 0 0 8px var(--bar-life-glow);
                                        "
                                ></div>
                            </div>

                            <div class="flex items-center justify-between pt-1">
                                <div class="flex gap-2">
                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'stress', math: 'sub', value: 1}) }}"
                                        style="background: var(--bar-stress)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        −
                                    </a>

                                    <a
                                        href="{{ path('app_maj_stat', {id: character.id, stat: 'stress', math: 'add', value: 1}) }}"
                                        style="background: var(--bar-stress)"
                                        class="flex h-8 w-8 items-center justify-center rounded-full border border-app text-sm font-bold text-app shadow-neon-soft hover:bg-panel-2"
                                    >
                                        +
                                    </a>
                                </div>

                                <span class="text-[10px] uppercase tracking-[0.2em] text-muted">Stress</span>

                                <div class="w-[72px]"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            {% include "main/_nav.html.twig" %}
        </div>
    </div>
{% endblock %}
