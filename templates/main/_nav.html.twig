<section class="card card--neon scanlines">
    <div class="space-y-3">
        <div class="grid grid-cols-5 gap-2">
            <a
                href="{{ path('app_main') }}"
                class="flex flex-col items-center justify-center gap-2 rounded-2xl border border-app bg-panel p-2 text-center shadow-neon-soft transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">🜁</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Perso
                </span>
            </a>
            <a
                href="{{ path('app_character_skills') }}"
                class="flex flex-col items-center justify-center gap-2 rounded-2xl border border-app bg-panel p-2 text-center shadow-neon-soft transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">⛯</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Skills
                </span>
            </a>
            <a
                href="{{ path('app_character_items') }}"
                class="flex flex-col items-center justify-center gap-2 rounded-2xl border border-app bg-panel p-2 text-center shadow-neon-soft transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">⌘</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Inventaire
                </span>
            </a>
            <a
                href="{{ path('app_social') }}"
                class="relative flex flex-col items-center justify-center gap-2 rounded-2xl border border-app bg-panel p-2 text-center shadow-neon-soft transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">＠</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Social
                </span>
                {% set totalUnread = 0 %}
                {% if app.user and character is defined %}
                    {% for cc in character.characterContacts %}
                        {% set totalUnread = totalUnread + cc.unreadCount %}
                    {% endfor %}
                {% endif %}
                {% if totalUnread > 0 %}
                    <span class="absolute -right-1 -top-1 flex h-4 w-4 items-center justify-center rounded-full bg-accent text-[8px] font-bold text-black shadow-neon">
                        {{ totalUnread }}
                    </span>
                {% endif %}
            </a>
            <a
                href="{{ path('app_character_actions') }}"
                class="flex flex-col items-center justify-center gap-2 rounded-2xl border border-app bg-panel p-2 text-center shadow-neon-soft transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">◈</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Actions
                </span>
            </a>
        </div>
    </div>
</section>
