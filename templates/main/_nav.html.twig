<nav class="fixed bottom-0 left-0 right-0 z-50 bg-app/90 backdrop-blur-lg border-t border-app px-4 pb-safe pt-2">
    <div class="mx-auto max-w-md">
        <div class="grid grid-cols-5 gap-2">
            <a
                href="{{ path('app_main') }}"
                class="flex flex-col items-center justify-center gap-1 rounded-xl p-1 text-center transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">🜁</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Perso
                </span>
            </a>
            <a
                href="{{ path('app_character_skills') }}"
                class="flex flex-col items-center justify-center gap-1 rounded-xl p-1 text-center transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">⛯</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Skills
                </span>
            </a>
            <a
                href="{{ path('app_character_items') }}"
                class="flex flex-col items-center justify-center gap-1 rounded-xl p-1 text-center transition hover:bg-panel-2"
            >
                <i class="fas fa-suitcase text-lg text-accent text-neon"></i>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    INV
                </span>
            </a>
            <a
                href="{{ path('app_social') }}"
                class="relative flex flex-col items-center justify-center gap-1 rounded-xl p-1 text-center transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">＠</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Social
                </span>
                {% set totalUnread = 0 %}
                {% if app.user and character is defined %}
                    {% for cc in character.characterContacts %}
                        {% set totalUnread = totalUnread + cc.unreadCount %}
                    {% endfor %}
                {% endif %}
                {% if totalUnread > 0 %}
                    <span class="absolute right-1 top-0 flex h-4 w-4 items-center justify-center rounded-full bg-accent text-[8px] font-bold text-black shadow-neon">
                        {{ totalUnread }}
                    </span>
                {% endif %}
            </a>
            <a
                href="{{ path('app_character_actions') }}"
                class="flex flex-col items-center justify-center gap-1 rounded-xl p-1 text-center transition hover:bg-panel-2"
            >
                <span class="text-lg text-accent text-neon">◈</span>
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-app leading-tight text-center">
                    Actions
                </span>
            </a>
        </div>
    </div>
</nav>
