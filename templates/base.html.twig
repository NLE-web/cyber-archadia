<!DOCTYPE html>
{% if is_granted("ROLE_USER") %}
    {% if app.user.themeColor %}
        <html data-theme="{{ app.user.themeColor }}">
    {% else %}
        <html data-theme="red">
    {% endif %}
    {% else %}
        <html data-theme="red">
{% endif %}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{% block title %}Archadia{% endblock %}</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body class="bg-app text-app">
<div class="min-h-dvh flex justify-center">
    <div class="w-full max-w-md">
        <div class="relative min-h-dvh overflow-hidden rounded-[28px] border border-app shadow-neon">
            <div class="flex min-h-dvh flex-col px-4 py-4">

                <header class="sticky top-0 z-20 flex flex-col items-center justify-center border-b border-app bg-app/80 backdrop-blur">
                    <div class="w-full px-4 py-3 flex items-center justify-center">
                        <h1 class="text-lg font-semibold tracking-[0.35em] text-accent text-neon">
                            ARCHADIA.NET
                        </h1>
                    </div>

                    {% if is_granted('ROLE_USER') and app.user.levelUpActive %}
                        <div id="levelup-banner" class="w-full bg-accent text-white py-2 text-center overflow-hidden transition-all duration-500 h-auto opacity-100">
                            <a href="{{ path('app_character_skills') }}" class="relative z-30 flex items-center justify-center gap-2 animate-pulse">
                                <i class="fas fa-bolt"></i>
                                <span class="text-xs font-bold uppercase tracking-[0.2em]">LEVEL UP DISPONIBLE !</span>
                                <i class="fas fa-bolt"></i>
                            </a>
                        </div>
                    {% elseif is_granted('ROLE_USER') %}
                        <div id="levelup-banner" class="w-full bg-accent text-white text-center overflow-hidden transition-all duration-500 h-0 opacity-0 pointer-events-none">
                            <a href="{{ path('app_character_skills') }}" class="relative z-30 flex items-center justify-center gap-2 animate-pulse">
                                <i class="fas fa-bolt"></i>
                                <span class="text-xs font-bold uppercase tracking-[0.2em]">LEVEL UP DISPONIBLE !</span>
                                <i class="fas fa-bolt"></i>
                            </a>
                        </div>
                    {% endif %}
                </header>

                <main class="flex-1 overflow-y-auto" id="main-container">
                    {% block body %}{% endblock %}
                </main>

                {% if is_granted('ROLE_USER') %}
                    <script type="text/javascript">
                        document.addEventListener('DOMContentLoaded', () => {
                            const eventSource = new EventSource("{{ (mercure_public_url|default('https://example.com/.well-known/mercure')) ~ '?topic=' ~ ('https://archadia.net/levelup'|url_encode) }}");
                            const banner = document.getElementById('levelup-banner');

                            eventSource.onmessage = event => {
                                const data = JSON.parse(event.data);
                                if (data.active) {
                                    banner.classList.remove('h-0', 'opacity-0', 'pointer-events-none');
                                    banner.classList.add('h-auto', 'opacity-100', 'py-2');
                                } else {
                                    banner.classList.add('h-0', 'opacity-0', 'pointer-events-none');
                                    banner.classList.remove('h-auto', 'opacity-100', 'py-2');
                                }
                            };
                        });
                    </script>
                {% endif %}
            </div>
        </div>
    </div>
</div>
</body>
</html>
