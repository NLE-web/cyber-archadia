<!DOCTYPE html>
{% if is_granted("ROLE_USER") %}
    {% if app.user.themeColor %}
        <html data-theme="{{ app.user.themeColor }}">
    {% else %}
        <html data-theme="red">
    {% endif %}
    {% else %}
        <html data-theme="red">
{% endif %}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{% block title %}Archadia{% endblock %}</title>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body class="bg-app text-app">
<div class="min-h-dvh flex justify-center">
    <div class="w-full max-w-md">
        <div class="relative min-h-dvh overflow-hidden rounded-[28px] border border-app shadow-neon">
            <div class="flex min-h-dvh flex-col px-4 py-4">

                <header class="sticky top-0 z-20 flex items-center justify-center border-b border-app bg-app/80 px-4 py-3 backdrop-blur">
                    <h1 class="text-lg font-semibold tracking-[0.35em] text-accent text-neon">
                        ARCHADIA.NET
                    </h1>
                </header>

                <main class="flex-1 overflow-y-auto">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </div>
</div>
</body>
</html>
