{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="flex min-h-full items-center justify-center">
        <div class="w-full max-w-xs">
            <header class="mb-6 text-center">
                <p class="text-xs uppercase tracking-[0.28em] text-muted text-neon">
                    Edgerunner interface
                </p>
                <h2 class="mt-2 text-lg font-semibold text-white">
                    Connexion
                </h2>
            </header>
            <section class="rounded-2xl border border-app bg-gradient-panel p-5 shadow-neon scanlines">
                {% if error %}
                    <div class="mb-4 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-300">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" class="space-y-4">
                    <div>
                        <label class="mb-2 block text-xs uppercase tracking-[0.2em] text-muted">
                            Nom d'utilisateur
                        </label>
                        <input
                            type="text"
                            value="{{ last_username }}"
                            name="_username"
                            autocomplete="username"
                            required
                            class="w-full rounded-xl border border-app bg-panel px-4 py-3 text-sm text-app"
                            placeholder="Votre identifiant"
                        >
                    </div>

                    <div>
                        <label class="mb-2 block text-xs uppercase tracking-[0.2em] text-muted">
                            Mot de passe
                        </label>
                        <input
                            type="password"
                            name="_password"
                            autocomplete="current-password"
                            required
                            class="w-full rounded-xl border border-app bg-panel px-4 py-3 text-sm text-app"
                            placeholder="••••••••"
                        >
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button class="w-full rounded-xl border border-accent bg-gradient-accent px-4 py-3 text-sm font-semibold text-black shadow-neon-soft">
                        Connexion
                    </button>
                </form>

            </section>
        </div>

    </div>
{% endblock %}
