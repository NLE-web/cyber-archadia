{% extends 'base.html.twig' %}

{% block title %}Downtime - {{ character.nom }}{% endblock %}

{% block body %}
{% for message in app.flashes('error') %}
    <div id="flash-error" class="fixed top-24 left-4 right-4 z-[100] bg-red-500 text-white px-6 py-4 rounded-2xl shadow-[0_0_20px_rgba(239,68,68,0.4)] border border-red-400/50 flex items-center gap-3 animate-slide-in">
        <i class="fas fa-exclamation-triangle text-xl"></i>
        <span class="font-bold">{{ message }}</span>
    </div>
{% endfor %}

<div class="flex flex-col gap-6 animate-fade-in pb-20">
    {% set preselectedTime = 0 %}
    {% for edt in downtimes %}
        {% if edt.selected or edt.downtime.forced %}
            {% set preselectedTime = preselectedTime + edt.downtime.timeCost %}
        {% endif %}
    {% endfor %}

    <div class="flex items-center justify-between border-b border-app pb-4">
        <h2 class="text-2xl font-bold tracking-tighter text-accent">DOWNTIME</h2>
        <div class="flex flex-col items-end">
            <span class="text-xs font-bold uppercase tracking-widest text-muted-app">Temps accumulé</span>
            <div id="total-time-display" class="text-xl font-black {{ preselectedTime > 24 ? 'text-red-500 animate-pulse' : 'text-app' }}">
                <span id="total-hours">{{ preselectedTime }}</span> / 24H
            </div>
        </div>
    </div>

    <div class="space-y-4">
        {% for edt in downtimes %}
            {% set isForced = edt.downtime.forced %}
            <div class="group relative border {{ isForced ? 'border-red-500/50 bg-red-500/5' : 'border-app bg-app-lighter' }} rounded-xl overflow-hidden transition-all duration-300 {{ edt.selected ? 'border-accent bg-accent/5 shadow-[0_0_15px_rgba(var(--accent-rgb),0.1)]' : (isForced ? 'hover:border-red-500' : 'hover:border-accent/50') }}">
                
                {# Bouton de sélection (Toute la tuile sauf le bouton info) #}
                <form action="{{ path('app_character_downtime_toggle', {id: edt.id}) }}" method="POST" class="m-0 downtime-form">
                    <button type="submit" class="w-full text-left p-4 flex items-start gap-3 {{ isForced ? 'cursor-default' : 'cursor-pointer' }}" {{ isForced ? 'onclick="return false;"' : '' }}>
                        <div class="pt-1">
                            {% if edt.selected or isForced %}
                                <i class="fas {{ isForced ? 'fa-exclamation-triangle text-red-500' : 'fa-check-circle text-accent' }} text-xl"></i>
                            {% else %}
                                <div class="w-5 h-5 rounded border-2 border-app-light group-hover:border-accent/50 transition-colors"></div>
                            {% endif %}
                        </div>

                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-start mb-1">
                                <h3 class="text-lg font-bold {{ isForced ? 'text-red-500' : (edt.selected ? 'text-accent' : 'text-app') }} leading-tight truncate mr-8">
                                    {{ edt.downtime.title }}
                                </h3>
                                <span class="text-xs font-bold {{ isForced ? 'text-red-500' : 'text-accent' }} uppercase tracking-widest shrink-0">
                                    {{ edt.downtime.timeCost }}H
                                </span>
                            </div>
                            <p class="text-sm text-app-light leading-snug line-clamp-2 italic">
                                {{ edt.downtime.description }}
                            </p>
                        </div>
                    </button>
                </form>

                {# Bouton info séparé #}
                <button onclick="toggleDowntime({{ edt.id }})" 
                        class="absolute right-4 bottom-4 w-5 h-5 flex items-center justify-center rounded-full bg-app/50 text-app-light hover:bg-accent/20 hover:text-accent transition-all z-10 border border-app-light/20">
                    <i class="fas fa-info text-xs"></i>
                </button>

                {# Contenu déployé (Effets) #}
                <div id="content-{{ edt.id }}" class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out {{ isForced ? 'bg-red-500/10' : 'bg-black/20' }}">
                    <div class="p-4 border-t {{ isForced ? 'border-red-500/20' : 'border-app/50' }} space-y-4">
                        <div class="{{ isForced ? 'bg-red-500/10 border border-red-500/20' : 'bg-accent/10 border border-accent/20' }} p-3 rounded-lg">
                            <span class="text-[10px] font-bold {{ isForced ? 'text-red-500' : 'text-accent' }} uppercase block mb-1">Effet</span>
                            <div class="text-sm text-app">
                                {{ edt.downtime.effet|parse_description }}
                            </div>
                            {% if edt.effetBonus %}
                                <div class="mt-2 pt-2 border-t {{ isForced ? 'border-red-500/20' : 'border-accent/20' }}">
                                    <span class="text-[10px] font-bold text-blue-400 uppercase block mb-1">Bonus MJ</span>
                                    <div class="text-sm text-app font-semibold">
                                        {{ edt.effetBonus }}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center py-12 border border-dashed border-app rounded-2xl">
                <i class="fas fa-couch text-4xl text-muted-app/20 mb-4 block"></i>
                <p class="text-muted-app text-sm">Aucune activité de downtime disponible pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</div>

<script>
    function toggleDowntime(id) {
        const content = document.getElementById('content-' + id);
        if (content.style.maxHeight && content.style.maxHeight !== '0px') {
            content.style.maxHeight = '0px';
        } else {
            content.style.maxHeight = content.scrollHeight + 'px';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Gestion des notifications flash
        const flash = document.getElementById('flash-error');
        if (flash) {
            setTimeout(() => {
                flash.classList.add('animate-slide-out');
                setTimeout(() => flash.remove(), 500);
            }, 3000);
        }

        // Gestion du maintien du scroll
        const scrollKey = 'downtime_scroll_pos';
        const savedScroll = localStorage.getItem(scrollKey);
        if (savedScroll) {
            window.scrollTo(0, parseInt(savedScroll));
            localStorage.removeItem(scrollKey);
        }

        document.querySelectorAll('.downtime-form').forEach(form => {
            form.addEventListener('submit', () => {
                localStorage.setItem(scrollKey, window.scrollY);
            });
        });
    });
</script>

<style>
    .animate-fade-in {
        animation: fadeIn 0.5s ease-out forwards;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-in {
        animation: slideIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }
    @keyframes slideIn {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-out {
        animation: slideOut 0.4s ease-in forwards;
    }
    @keyframes slideOut {
        from { opacity: 1; transform: translateY(0); }
        to { opacity: 0; transform: translateY(-20px); }
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
{% endblock %}
