{% extends 'base.html.twig' %}

{% block title %}Downtime - {{ character.nom }}{% endblock %}

{% block body %}
<div class="flex flex-col gap-6 animate-fade-in pb-44">
    {% set preselectedTime = 0 %}
    {% for edt in downtimes %}
        {% if edt.discard %}
            {% set preselectedTime = preselectedTime + edt.downtime.timeCost %}
        {% endif %}
    {% endfor %}

    <div class="flex items-center justify-between border-b border-app pb-4">
        <h2 class="text-2xl font-bold tracking-tighter text-accent">DOWNTIME</h2>
        <div class="flex flex-col items-end">
            <span class="text-xs font-bold uppercase tracking-widest text-muted-app">Temps accumulé</span>
            <div id="total-time-display" class="text-xl font-black text-app">
                <span id="total-hours">{{ preselectedTime }}</span> / 24H
            </div>
        </div>
    </div>

    <form action="{{ path('app_character_downtime_validate') }}" method="POST">
        <div class="space-y-4">
            {% for edt in downtimes %}
                {% set isForced = edt.downtime.forced %}
                <div class="group border {{ isForced ? 'border-red-500/50 bg-red-500/5' : 'border-app bg-app-lighter' }} rounded-xl overflow-hidden transition-all duration-300 {{ edt.discard ? 'opacity-50 grayscale' : (isForced ? 'hover:border-red-500' : 'hover:border-accent') }}">
                    <div class="p-4 flex items-start gap-3">
                        {% if not edt.discard %}
                            <div class="pt-1">
                                <input type="checkbox" name="downtimes[]" value="{{ edt.id }}" 
                                       data-cost="{{ edt.downtime.timeCost }}"
                                       {{ isForced ? 'checked onclick="return false;"' : 'onchange="updateTotalTime()"' }}
                                       class="downtime-checkbox w-5 h-5 rounded {{ isForced ? 'border-red-500 bg-red-900/20 text-red-500' : 'border-app bg-app text-accent focus:ring-accent' }}">
                            </div>
                        {% else %}
                            <div class="pt-1">
                                <i class="fas fa-check-circle text-green-500 text-xl"></i>
                            </div>
                        {% endif %}

                        <div class="flex-1 min-w-0 cursor-pointer" onclick="toggleDowntime({{ edt.id }})">
                            <div class="flex justify-between items-start mb-1">
                                <h3 class="text-lg font-bold {{ isForced ? 'text-red-500' : 'text-app' }} leading-tight truncate mr-2">
                                    {{ isForced ? '<i class="fas fa-exclamation-triangle mr-1"></i>' : '' }}
                                    {{ edt.downtime.title }}
                                </h3>
                                <span class="text-xs font-bold {{ isForced ? 'text-red-500' : 'text-accent' }} uppercase tracking-widest shrink-0">
                                    {{ edt.downtime.timeCost }}H
                                </span>
                            </div>
                            <p class="text-sm text-app-light leading-snug line-clamp-2 italic">
                                {{ edt.downtime.description }}
                            </p>
                        </div>
                    </div>

                    {# Contenu déployé (Effets) #}
                    <div id="content-{{ edt.id }}" class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out {{ isForced ? 'bg-red-500/10' : 'bg-black/20' }}">
                        <div class="p-4 border-t {{ isForced ? 'border-red-500/20' : 'border-app/50' }} space-y-4">
                            <div class="{{ isForced ? 'bg-red-500/10 border border-red-500/20' : 'bg-accent/10 border border-accent/20' }} p-3 rounded-lg">
                                <span class="text-[10px] font-bold {{ isForced ? 'text-red-500' : 'text-accent' }} uppercase block mb-1">Effet</span>
                                <div class="text-sm text-app">
                                    {{ edt.downtime.effet|parse_description }}
                                </div>
                                {% if edt.effetBonus %}
                                    <div class="mt-2 pt-2 border-t {{ isForced ? 'border-red-500/20' : 'border-accent/20' }}">
                                        <span class="text-[10px] font-bold text-blue-400 uppercase block mb-1">Bonus MJ</span>
                                        <div class="text-sm text-app font-semibold">
                                            {{ edt.effetBonus }}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="text-center py-12 border border-dashed border-app rounded-2xl">
                    <i class="fas fa-couch text-4xl text-muted-app/20 mb-4 block"></i>
                    <p class="text-muted-app text-sm">Aucune activité de downtime disponible pour le moment.</p>
                </div>
            {% endfor %}
        </div>

        {% if downtimes|length > 0 %}
            <div class="fixed bottom-24 left-4 right-4 max-w-md mx-auto z-30">
                <button type="submit" id="submit-btn" disabled
                        class="w-full py-4 bg-accent text-white font-bold uppercase tracking-[0.2em] text-sm rounded-xl shadow-2xl transition-all duration-300 opacity-50 cursor-not-allowed">
                    Valider la sélection (<span id="btn-hours">0</span>h)
                </button>
            </div>
        {% endif %}
    </form>
</div>

<script>
    const preselectedTime = {{ preselectedTime }};

    function toggleDowntime(id) {
        const content = document.getElementById('content-' + id);
        if (content.style.maxHeight && content.style.maxHeight !== '0px') {
            content.style.maxHeight = '0px';
        } else {
            content.style.maxHeight = content.scrollHeight + 'px';
        }
    }

    function updateTotalTime() {
        const checkboxes = document.querySelectorAll('.downtime-checkbox:checked');
        let total = preselectedTime;
        let newSelectedCount = 0;
        
        checkboxes.forEach(cb => {
            // On ne compte dans le total JS que ce qui n'est PAS déjà dans le preselectedTime (discard = true)
            // Mais attente, le preselectedTime est calculé sur edt.discard en Twig.
            // Si une checkbox est "forced", elle est déjà cochée et a data-cost.
            // On veut le total absolu pour la limite de 24h.
            total += parseInt(cb.dataset.cost);
            
            // On compte comme "nouvelle sélection" seulement ce qui n'est pas "forced" et pas encore "discard"
            // Les forced non-discard sont cochées par défaut mais doivent être validées
            if (!cb.onclick) { // Simple check pour identifier mes checkboxes normales vs forced
                 newSelectedCount++;
            }
        });

        const totalDisplay = document.getElementById('total-hours');
        const btnHours = document.getElementById('btn-hours');
        const submitBtn = document.getElementById('submit-btn');
        const displayContainer = document.getElementById('total-time-display');

        totalDisplay.innerText = total;
        
        // Calcul du temps à valider (ce qui est coché et non discard)
        let forcedToValidateCost = 0;
        document.querySelectorAll('.downtime-checkbox[onclick]').forEach(cb => {
            forcedToValidateCost += parseInt(cb.dataset.cost);
        });
        
        let normalToValidateCost = 0;
        document.querySelectorAll('.downtime-checkbox:not([onclick]):checked').forEach(cb => {
            normalToValidateCost += parseInt(cb.dataset.cost);
        });

        btnHours.innerText = forcedToValidateCost + normalToValidateCost;

        if (total > 24) {
            displayContainer.classList.remove('text-app');
            displayContainer.classList.add('text-red-500', 'animate-pulse');
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            submitBtn.classList.remove('opacity-100');
        } else {
            displayContainer.classList.add('text-app');
            displayContainer.classList.remove('text-red-500', 'animate-pulse');
            
            // Le bouton est actif s'il y a quelque chose à valider (normal ou forcé)
            if ((forcedToValidateCost + normalToValidateCost) > 0) {
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                submitBtn.classList.add('opacity-100');
            } else {
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
                submitBtn.classList.remove('opacity-100');
            }
        }
    }

    // Initialisation au cas où
    document.addEventListener('DOMContentLoaded', () => {
        updateTotalTime();
    });
</script>

<style>
    .animate-fade-in {
        animation: fadeIn 0.5s ease-out forwards;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
{% endblock %}
